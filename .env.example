# Environment Variables for Secure Chat Application

# Django Settings
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-use-django-secret-key-generator
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,ngrok-free.app

# Database Configuration (MySQL)
DB_NAME=secure_chat_db
DB_USER=chatuser
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=3306

# Security Settings (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_TIMEOUT=300

# Redis (Optional - for production with multiple workers)
# REDIS_HOST=localhost
# REDIS_PORT=6379
